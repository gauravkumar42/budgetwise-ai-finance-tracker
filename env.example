# ─────────────────────────────────────────────
#  Personal Finance Tracker — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local:   mongodb://localhost:27017/finance_tracker
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/finance_tracker
MONGO_URI=mongodb://localhost:27017/finance_tracker

# JWT
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# OpenAI
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
